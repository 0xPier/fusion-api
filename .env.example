# ─────────────────────────────────────────────────────────────
# Fusion API environment. Copy to `.env` and fill in.
# Secrets live here, never in config.yaml or logs (guardrail G2).
# ─────────────────────────────────────────────────────────────

# ── Cloud provider API keys (leave blank to disable that provider) ──
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Local OpenAI-compatible servers (defaults shown) ──
OLLAMA_BASE_URL=http://localhost:11434/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LLAMACPP_BASE_URL=http://localhost:8080/v1

# ── Fusion defaults (overridable per request) ──
FUSION_DEFAULT_PRESET=quality
FUSION_MAX_PANEL_MODELS=8
FUSION_TIMEOUT_MS=120000
# Hard cap on estimated USD per request. Blank = no cap.
FUSION_MAX_USD_PER_REQUEST=

# ── Server ──
PORT=3000
# Optional path to a YAML/JSON config file (see config.example.yaml).
CONFIG_PATH=./config.yaml
LOG_LEVEL=info
